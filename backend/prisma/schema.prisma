// NexusWait Prisma Schema - see docs/implementation/03-domain-and-database.md
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  active
  paused
  archived
}

enum HostedPageStatus {
  draft
  published
  archived
}

enum NotificationStatus {
  pending
  sent
  failed
  dead_letter
}

enum ApiKeyType {
  secret
  publishable
}

enum PlanTier {
  spark
  pulse
  nexus
  enterprise
}

enum IntegrationType {
  mailchimp
  sendgrid
  slack
  discord
  hubspot
  zapier
  google_sheets
  segment
  supabase
  intercom
  webhook
}

enum UserRole {
  user
  admin
}

model Account {
  id                    String    @id @default(uuid())
  plan                  PlanTier  @default(spark)
  polarCustomerId       String?   @map("polar_customer_id")
  polarSubscriptionId  String?   @map("polar_subscription_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  users           User[]
  projects        Project[]
  apiKeys         ApiKey[]
  polarSubscription PolarSubscription?
  inAppNotifications    InAppNotification[]
  notificationPreferences NotificationPreference[]
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  firstName    String?    @map("first_name")
  lastName     String?    @map("last_name")
  googleId     String?    @unique @map("google_id")
  provider     String     @default("local")
  avatarUrl    String?    @map("avatar_url")
  roles           UserRole[] @default([user])
  emailVerifiedAt DateTime?  @map("email_verified_at")
  accountId       String     @map("account_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  status      ProjectStatus @default(active)
  redirectUrl String?       @map("redirect_url")
  webhookUrl    String?       @map("webhook_url")
  customFields  Json?         @map("custom_fields")
  accountId     String        @map("account_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  account        Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscribers     Subscriber[]
  integrations    Integration[]
  hostedPage      HostedPage?
}

model Subscriber {
  id           String   @id @default(uuid())
  email        String
  name         String?
  metadata     Json?
  referralCode String   @unique @map("referral_code")
  referrerId   String?  @map("referrer_id")
  verifiedAt   DateTime? @map("verified_at")
  source       String?  @default("direct")
  projectId   String   @map("project_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  referrer Subscriber? @relation("Referrals", fields: [referrerId], references: [id])
  referred Subscriber[] @relation("Referrals")

  @@unique([projectId, email])
  @@index([projectId, referralCode])
  @@index([referrerId])
}

model Integration {
  id                String          @id @default(uuid())
  type              IntegrationType
  displayName       String          @map("display_name")
  config            Json
  fieldMapping      Json?           @map("field_mapping")
  events            String[]
  enabled           Boolean         @default(true)
  lastTriggeredAt   DateTime?       @map("last_triggered_at")
  failureCount      Int             @default(0) @map("failure_count")
  maxRetryAttempts  Int             @default(5) @map("max_retry_attempts")
  projectId         String          @map("project_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveryLogs WebhookDeliveryLog[]
}

model HostedPage {
  id              String           @id @default(uuid())
  slug            String
  customDomain    String?          @map("custom_domain")
  title           String
  metaDescription String?          @map("meta_description")
  ogImageUrl      String?          @map("og_image_url")
  themeId         String           @map("theme_id")
  themeOverrides  Json?            @map("theme_overrides")
  sections        Json
  formConfig      Json             @map("form_config")
  successConfig   Json             @map("success_config")
  status          HostedPageStatus @default(draft)
  publishedAt     DateTime?        @map("published_at")
  projectId       String           @unique @map("project_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}


model Notification {
  id          String             @id @default(uuid())
  templateId  String             @map("template_id")
  recipient   String
  payload     Json
  status      NotificationStatus @default(pending)
  attempts    Int                @default(0)
  maxAttempts Int                @default(3) @map("max_attempts")
  nextRetryAt DateTime?          @map("next_retry_at")
  lastError   String?            @map("last_error")
  sentAt      DateTime?         @map("sent_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String
  channel   String
  subject   String?
  body      String
  accountId String?  @map("account_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notifications Notification[]
}

model InAppNotification {
  id        String    @id @default(uuid())
  accountId String    @map("account_id")
  title     String
  body      String
  type      String    @default("info")
  actionUrl String?   @map("action_url")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, readAt])
  @@map("in_app_notification")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  event     String
  channels  String[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, event])
  @@map("notification_preference")
}

model ApiKey {
  id        String     @id @default(uuid())
  keyHash   String     @map("key_hash")
  prefix    String
  type      ApiKeyType
  projectId String?    @map("project_id")
  accountId String     @map("account_id")
  createdAt DateTime   @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PolarSubscription {
  id                   String   @id @default(uuid())
  polarSubscriptionId  String   @unique @map("polar_subscription_id")
  polarCustomerId      String   @map("polar_customer_id")
  plan                 PlanTier
  status               String
  accountId            String   @unique @map("account_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PlatformConfig {
  id         String   @id @default("singleton")
  apiBaseUrl String   @default("https://api.nexuswait.com") @map("api_base_url")
  cdnBaseUrl String   @default("https://cdn.nexuswait.com") @map("cdn_base_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

model PlanConfig {
  id                    String   @id @default(uuid())
  tier                  PlanTier @unique
  displayName           String   @map("display_name")
  description           String?
  monthlyPriceCents     Int      @map("monthly_price_cents")
  yearlyPriceCents      Int      @map("yearly_price_cents")
  maxProjects           Int?     @map("max_projects")
  maxSubscribersMonth   Int?     @map("max_subscribers_month")
  maxIntegrations       Int?     @map("max_integrations")
  features              String[]
  polarProductIdMonthly String?  @map("polar_product_id_monthly")
  polarProductIdYearly  String?  @map("polar_product_id_yearly")
  highlight             Boolean  @default(false)
  ctaText               String   @default("Get Started") @map("cta_text")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("plan_config")
}

model WebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  eventType String   @map("event_type")
  payload   Json
  status    String   @default("processed")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@map("webhook_event")
}

model WebhookDeliveryLog {
  id             String      @id @default(uuid())
  integrationId  String      @map("integration_id")
  event          String
  payload        Json
  idempotencyKey String      @unique @map("idempotency_key")
  responseStatus Int?        @map("response_status")
  responseBody   String?     @map("response_body")
  durationMs     Int?        @map("duration_ms")
  error          String?
  success        Boolean     @default(false)
  createdAt      DateTime    @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
  @@map("webhook_delivery_log")
}
